# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
REQUIRED_USER_TELEGRAM_ID=123456789

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=vanessa
POSTGRES_PASSWORD=vanessa
POSTGRES_DB=vanessa

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=messages

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Anthropic (generation)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# RAG
RAG_CONTEXT_MIN=20
RAG_CONTEXT_MAX=50
RAG_HYBRID_TOP_K=20
RAG_EMBED_CACHE_SIZE=256
RAG_EMBED_MAX_CHARS=2000
RAG_ANCHOR_MAX=10
RAG_CONTEXT_WINDOW_BEFORE=10
RAG_CONTEXT_WINDOW_AFTER=10
RAG_CONTEXT_WINDOW_MAX_TOTAL=220
RAG_QUERY_REWRITE_USE_LLM=true
RAG_VECTOR_MIN_SCORE=0.35

# Qdrant memory tuning (~200k vectors)
QDRANT_ON_DISK=true
QDRANT_QUANTIZATION_ENABLED=true
QDRANT_INDEXING_THRESHOLD=20000
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=64

# PostgreSQL pool (API process)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2

# Decision engine (session tuning → config/content.yaml conversation section)
DECISION_RELEVANCE_THRESHOLD=0.76
DECISION_RATE_LIMIT_PER_MINUTE=10
DECISION_BOT_NAMES=
DECISION_TRIGGER_KEYWORDS=
DECISION_PLANNER_PREFILTER=true

# Content
CONTENT_CONFIG_PATH=config/content.yaml

# History import: poetry run python scripts/import_telegram_history.py --export ...

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api:8000
API_INTERNAL_TOKEN=
API_AUTO_CREATE_SCHEMA=false
INDEXING_MAX_RETRIES=2
LLM_MAX_RETRIES=2

# Logging
LOG_LEVEL=INFO
